{
	"app-id": "io.github.shaweel.shaweelTimer",
	"runtime": "org.gnome.Platform",
	"runtime-version": "49",
	"sdk": "org.gnome.Sdk",
	"command": "shaweeltimer",
	"finish-args": [
		"--share=ipc",
		"--socket=wayland",
		"--socket=fallback-x11",
		"--device=dri"
	],
	"modules": [
		{
			"name": "shaweeltimer",
			"buildsystem": "simple",
			"build-commands": [
				"install -Dm755 main.py /app/lib/shaweelTimer/main.py",
				"install -Dm755 status.py /app/lib/shaweelTimer/status.py",
				"install -Dm755 config.py /app/lib/shaweelTimer/config.py",
				"install -Dm755 shaweeltimer /app/bin/shaweeltimer",
				"install -Dm644 shaweeltimer.desktop /app/share/applications/io.github.shaweel.shaweelTimer.desktop",
				"install -Dm644 metadata.json /app/lib/shaweelTimer/metadata.json",
				"install -Dm644 assets/shaweelTimer.png /app/share/icons/hicolor/256x256/apps/io.github.shaweel.shaweelTimer.png"
			],
			"sources": [
				{
					"type": "dir",
					"path": "."
				}
			]
		}
	]
}