{
	"app-id": "io.github.shaweel.shaweelTimer",
	"runtime": "org.gnome.Platform",
	"runtime-version": "49",
	"sdk": "org.gnome.Sdk",
	"command": "shaweeltimer",
	"separate-locales": false,
	"finish-args": [
		"--share=ipc",
		"--socket=wayland",
		"--socket=fallback-x11",
		"--device=dri"
	],
	"modules": [
		{
			"name": "shaweeltimer",
			"buildsystem": "simple",
			"build-commands": [
				"install -Dm755 main.py /app/lib/shaweelTimer/main.py",
				"install -Dm755 status.py /app/lib/shaweelTimer/status.py",
				"install -Dm755 config.py /app/lib/shaweelTimer/config.py",
				"install -Dm755 shaweeltimer-flatpak /app/bin/shaweeltimer",
				"install -Dm644 io.github.shaweel.shaweelTimer.desktop /app/share/applications/io.github.shaweel.shaweelTimer.desktop",
				"install -Dm644 metadata.json /app/lib/shaweelTimer/metadata.json",
				"install -Dm644 io.github.shaweel.shaweelTimer.metainfo.xml /app/share/metainfo/io.github.shaweel.shaweelTimer.metainfo.xml",
				"install -Dm644 assets/shaweelTimer.png /app/share/icons/hicolor/256x256/apps/io.github.shaweel.shaweelTimer.png"
			],
			"sources": [
				{
				"type": "git",
				"url": "https://github.com/shaweel/shaweelTimer.git",
				"tag": "v1.1.1",
				"commit": "68bb2beb7bfecb6bb2ee4350a7e7dc432ae1a2ea"
			}
			]
		}
	]
}